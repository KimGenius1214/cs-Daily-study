# Notion Integration Token (notion.so/my-integrations 에서 발급)
# 실제 토큰을 여기에 박지 말고, 이 파일을 .env 로 복사한 뒤 .env 에서만 값 채우세요.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CS Daily Knowledge DB ID (DB URL 끝부분의 32자 hex)
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (Claude Code가 이미 인증돼있으면 생략 가능)
ANTHROPIC_API_KEY=sk-ant-xxxxx
